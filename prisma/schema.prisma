generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Donation {
  id          Int      @id @default(autoincrement())
  amount      Float
  donorName   String?
  donorEmail  String?
  blessing    String?
  slipUrl     String?
  date        DateTime @default(now())
  status      String   @default("pending")
}

model WebsiteSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
